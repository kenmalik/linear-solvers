{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CUDA C++: Launch With Preconditioner",
            "type": "cuda-gdb",
            "request": "launch",
            "program": "${workspaceFolder}/build/cgrun",
            "args": [
                "--real-residual",
                "-b",
                "${workspaceFolder}/test/data/1138_bus_b.mat",
                "${workspaceFolder}/test/data/1138_bus.mat",
                "${workspaceFolder}/test/data/1138_bus_ichol.mat"
            ]
        },
        {
            "name": "CUDA C++: Launch No Preconditioner",
            "type": "cuda-gdb",
            "request": "launch",
            "program": "${workspaceFolder}/build/cgrun",
            "args": [
                "--real-residual",
                "-b",
                "${workspaceFolder}/test/data/1138_bus_b.mat",
                "${workspaceFolder}/test/data/1138_bus.mat",
            ]
        },
        {
            "name": "CUDA C++: Attach",
            "type": "cuda-gdb",
            "request": "attach"
        }
    ]
}
